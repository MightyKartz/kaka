{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaka.local/schemas/host-shell-pilot-evidence-manifest.schema.json",
  "title": "Pocket Agent Host Shell Pilot Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "surface",
    "runtime",
    "ok",
    "manifest_status",
    "runtime_side_only",
    "phone_api_path",
    "phone_api_unchanged",
    "p3_4_complete",
    "p3_4_completion_owner",
    "package",
    "artifacts",
    "artifact_review_summary",
    "archive_gates",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": "kaka.host_shell_pilot_evidence_manifest.v1"
    },
    "surface": {
      "const": "hermes_openclaw_host_shell_pilot_evidence_manifest"
    },
    "runtime": {
      "enum": [
        "hermes",
        "openclaw"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "manifest_status": {
      "enum": [
        "blocked_missing_artifacts",
        "blocked_artifact_review",
        "ready_for_archive"
      ]
    },
    "runtime_side_only": {
      "const": true
    },
    "phone_api_path": {
      "const": "/mobile/v1"
    },
    "phone_api_unchanged": {
      "const": true
    },
    "p3_4_complete": {
      "const": false
    },
    "p3_4_completion_owner": {
      "const": "external_host_shell"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "created_at",
        "archive_filename",
        "archive_creation"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "archive_filename": {
          "type": "string"
        },
        "archive_creation": {
          "const": "external"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "required",
          "path",
          "loaded",
          "schema_version",
          "surface",
          "runtime",
          "ok",
          "byte_size",
          "sha256",
          "blocking_reason"
        ],
        "properties": {
          "id": {
            "enum": [
              "preflight_json",
              "conformance_json",
              "receipt_json",
              "handoff_json",
              "artifact_review_json",
              "request_json",
              "runbook_json"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "path": {
            "type": "string"
          },
          "loaded": {
            "type": "boolean"
          },
          "schema_version": {
            "type": "string"
          },
          "surface": {
            "type": "string"
          },
          "runtime": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "byte_size": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string"
          },
          "blocking_reason": {
            "type": "string"
          }
        }
      }
    },
    "artifact_review_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provided",
        "review_status",
        "can_submit_to_external_review",
        "can_mark_p3_4_complete"
      ],
      "properties": {
        "provided": {
          "type": "boolean"
        },
        "review_status": {
          "type": "string"
        },
        "can_submit_to_external_review": {
          "type": "boolean"
        },
        "can_mark_p3_4_complete": {
          "const": false
        }
      }
    },
    "archive_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_required_artifacts_present",
        "artifact_review_ready",
        "can_create_external_archive",
        "can_mark_p3_4_complete",
        "blocking_reasons"
      ],
      "properties": {
        "all_required_artifacts_present": {
          "type": "boolean"
        },
        "artifact_review_ready": {
          "type": "boolean"
        },
        "can_create_external_archive": {
          "type": "boolean"
        },
        "can_mark_p3_4_complete": {
          "const": false
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_side_only",
        "phone_api_unchanged",
        "phone_settings_owner",
        "no_proprietary_binary_bundled_by_kaka",
        "does_not_invoke_private_adapter_command",
        "does_not_run_conformance",
        "does_not_fetch_audit_refs",
        "does_not_submit_handoff",
        "does_not_mutate_host_state",
        "does_not_create_archive_by_default",
        "hashes_local_artifact_files_only"
      ],
      "properties": {
        "runtime_side_only": {
          "const": true
        },
        "phone_api_unchanged": {
          "const": true
        },
        "phone_settings_owner": {
          "const": false
        },
        "no_proprietary_binary_bundled_by_kaka": {
          "const": true
        },
        "does_not_invoke_private_adapter_command": {
          "const": true
        },
        "does_not_run_conformance": {
          "const": true
        },
        "does_not_fetch_audit_refs": {
          "const": true
        },
        "does_not_submit_handoff": {
          "const": true
        },
        "does_not_mutate_host_state": {
          "const": true
        },
        "does_not_create_archive_by_default": {
          "const": true
        },
        "hashes_local_artifact_files_only": {
          "const": true
        }
      }
    }
  }
}
