{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaka.local/schemas/host-shell-pilot-artifact-review.schema.json",
  "title": "Kaka Host Shell Pilot Artifact Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "surface",
    "runtime",
    "ok",
    "review_status",
    "runtime_side_only",
    "phone_api_path",
    "phone_api_unchanged",
    "p3_4_complete",
    "p3_4_completion_owner",
    "artifacts",
    "artifact_consistency",
    "release_review",
    "safety"
  ],
  "properties": {
    "schema_version": {
      "const": "kaka.host_shell_pilot_artifact_review.v1"
    },
    "surface": {
      "const": "hermes_openclaw_host_shell_pilot_artifact_review"
    },
    "runtime": {
      "enum": [
        "hermes",
        "openclaw"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "review_status": {
      "enum": [
        "ready_for_external_review",
        "blocked"
      ]
    },
    "runtime_side_only": {
      "const": true
    },
    "phone_api_path": {
      "const": "/mobile/v1"
    },
    "phone_api_unchanged": {
      "const": true
    },
    "p3_4_complete": {
      "const": false
    },
    "p3_4_completion_owner": {
      "const": "external_host_shell"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preflight",
        "conformance",
        "receipt",
        "handoff"
      ],
      "properties": {
        "preflight": {
          "$ref": "#/$defs/artifact"
        },
        "conformance": {
          "$ref": "#/$defs/artifact"
        },
        "receipt": {
          "$ref": "#/$defs/artifact"
        },
        "handoff": {
          "$ref": "#/$defs/artifact"
        }
      }
    },
    "artifact_consistency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_match",
        "preflight_allows_conformance",
        "conformance_passed",
        "conformance_embedded_in_receipt",
        "receipt_ready",
        "receipt_embedded_in_handoff",
        "handoff_ready_to_submit",
        "audit_refs_complete",
        "no_synthetic_conformance",
        "private_adapter_command_consistent"
      ],
      "properties": {
        "runtime_match": {
          "type": "boolean"
        },
        "preflight_allows_conformance": {
          "type": "boolean"
        },
        "conformance_passed": {
          "type": "boolean"
        },
        "conformance_embedded_in_receipt": {
          "type": "boolean"
        },
        "receipt_ready": {
          "type": "boolean"
        },
        "receipt_embedded_in_handoff": {
          "type": "boolean"
        },
        "handoff_ready_to_submit": {
          "type": "boolean"
        },
        "audit_refs_complete": {
          "type": "boolean"
        },
        "no_synthetic_conformance": {
          "type": "boolean"
        },
        "private_adapter_command_consistent": {
          "type": "boolean"
        }
      }
    },
    "release_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_submit_to_external_review",
        "can_mark_p3_4_complete",
        "blocking_reasons"
      ],
      "properties": {
        "can_submit_to_external_review": {
          "type": "boolean"
        },
        "can_mark_p3_4_complete": {
          "const": false
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_side_only",
        "phone_api_unchanged",
        "phone_settings_owner",
        "no_proprietary_binary_bundled_by_kaka",
        "does_not_invoke_private_adapter_command",
        "does_not_run_conformance",
        "does_not_fetch_audit_refs",
        "does_not_mutate_host_state"
      ],
      "properties": {
        "runtime_side_only": {
          "const": true
        },
        "phone_api_unchanged": {
          "const": true
        },
        "phone_settings_owner": {
          "const": false
        },
        "no_proprietary_binary_bundled_by_kaka": {
          "const": true
        },
        "does_not_invoke_private_adapter_command": {
          "const": true
        },
        "does_not_run_conformance": {
          "const": true
        },
        "does_not_fetch_audit_refs": {
          "const": true
        },
        "does_not_mutate_host_state": {
          "const": true
        }
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "path",
        "loaded",
        "schema_valid",
        "schema_errors",
        "schema_version",
        "runtime",
        "ok",
        "status",
        "summary",
        "blocking_reason"
      ],
      "properties": {
        "required": {
          "const": true
        },
        "path": {
          "type": "string"
        },
        "loaded": {
          "type": "boolean"
        },
        "schema_valid": {
          "type": "boolean"
        },
        "schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "schema_version": {
          "type": "string"
        },
        "runtime": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "summary": {
          "type": "object"
        },
        "blocking_reason": {
          "type": "string"
        }
      }
    }
  }
}
